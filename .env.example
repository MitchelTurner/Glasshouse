# PostgreSQL — YouTube Transcript database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/youtube_transcripts

# Claude LLM — use Anthropic directly OR OpenRouter (at least one required)
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Pipeline options
LOOKBACK_DAYS=14
MAX_TRANSCRIPTS=10
MAX_RESEARCH_QUERIES=3
MAX_TRANSCRIPT_CHARS=6000
LLM_MAX_TOKENS=8192
DRY_RUN=false

# Daily automation
DAILY_SCAN_ENABLED=true
DAILY_SCAN_HOUR=8
DAILY_SCAN_MINUTE=0
DAILY_SCAN_TIMEZONE=UTC
TELEGRAM_POLLING_ENABLED=true
